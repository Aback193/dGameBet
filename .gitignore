# ============================================
.env
.env.local
.env.test
.env.*.local
*.pem
*.key

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Build Outputs
# ============================================
dist/
build/
.next/
out/

# ============================================
# Smart Contracts (Foundry)
# ============================================
contracts/cache/
contracts/out/
contracts/broadcast/
contracts/lib/

# ============================================
# Coverage Reports
# ============================================
coverage/
lcov.info
*.lcov
.nyc_output/

# ============================================
# IDE & Editor
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Testing
# ============================================
playwright-report/
test-results/
.playwright/

# ============================================
# Temporary Files
# ============================================
temp/
tmp/
*.tmp
*.temp

# ============================================
# Docker
# ============================================
.docker/

# ============================================
# Misc
# ============================================
*.tgz
*.zip
*.tar.gz
